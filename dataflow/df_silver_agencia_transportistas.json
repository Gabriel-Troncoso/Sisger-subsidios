{
	"name": "df_silver_agencia_transportistas",
	"properties": {
		"folder": {
			"name": "silver/silver_agencia_sedem"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_agencia_transportistas",
						"type": "DatasetReference"
					},
					"name": "srcbronzeagenciatransportistas"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_agencia_transportistas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          transportista_id as string,",
				"          razon_social as string,",
				"          nit as string,",
				"          municipio as string,",
				"          contacto as string,",
				"          telefono as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzeagenciatransportistas",
				"srcbronzeagenciatransportistas derive(transportista_id = toInteger(trim(transportista_id)),",
				"          razon_social = initCap(lower(trim(razon_social))),",
				"          nit =  upper(trim(nit)),",
				"          municipio = initCap(lower(trim(municipio))),",
				"          contacto = initCap(lower(trim(contacto))),",
				"          telefono = trim(telefono),",
				"          estado = initCap(lower(trim(estado)))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          transportista_id as integer,",
				"          razon_social as string,",
				"          nit as string,",
				"          municipio as string,",
				"          contacto as string,",
				"          telefono as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     preSQLs:['DELETE FROM silver.agencia_transportistas;'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}