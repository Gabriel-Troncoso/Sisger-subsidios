{
	"name": "df_silver_bja_pagos",
	"properties": {
		"folder": {
			"name": "silver/silver_bja"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_bja_pagos",
						"type": "DatasetReference"
					},
					"name": "srcbronzebjapagos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_bja_pagos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          pago_id as string,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as string,",
				"          fecha_pago as string,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzebjapagos",
				"srcbronzebjapagos derive(pago_id = toInteger(trim(pago_id)),",
				"          ci_beneficiaria = upper(trim(ci_beneficiaria)),",
				"          concepto_pago = initCap(lower(trim(concepto_pago))),",
				"          monto_bs = toDecimal(replace(trim(monto_bs), ',', '.'), 10, 2),",
				"          fecha_pago = coalesce(     toDate(fecha_pago, 'yyyy-MM-dd'),     toDate(fecha_pago, 'dd/MM/yyyy'),     toDate(fecha_pago, 'dd-MM-yyyy'),     toDate(fecha_pago, 'MM/dd/yyyy') ),",
				"          estado_pago = initCap(lower(trim(estado_pago))),",
				"          canal_pago = initCap(lower(trim(canal_pago))),",
				"          nro_comprobante = upper(trim(nro_comprobante))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          pago_id as integer,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as decimal(10,2),",
				"          fecha_pago as date,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     preSQLs:['DELETE FROM silver.bja_pagos;'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}