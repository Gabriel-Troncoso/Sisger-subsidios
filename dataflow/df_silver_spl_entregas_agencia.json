{
	"name": "df_silver_spl_entregas_agencia",
	"properties": {
		"folder": {
			"name": "silver/silver_spl"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_spl_entregas_agencia",
						"type": "DatasetReference"
					},
					"name": "srcbronzesplentregasagencia"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_spl_entregas_agencia",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_agencia_id as string,",
				"          asignacion_id as string,",
				"          ci_beneficiaria as string,",
				"          fecha_entrega as string,",
				"          productos as string,",
				"          lote as string,",
				"          peso_kg as string,",
				"          punto_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzesplentregasagencia",
				"srcbronzesplentregasagencia derive(entrega_agencia_id = toInteger(trim(entrega_agencia_id)),",
				"          asignacion_id = toInteger(trim(asignacion_id)),",
				"          ci_beneficiaria = upper(trim(ci_beneficiaria)),",
				"          fecha_entrega = coalesce(     toDate(fecha_entrega, 'yyyy-MM-dd'),     toDate(fecha_entrega, 'dd/MM/yyyy'),     toDate(fecha_entrega, 'dd-MM-yyyy'),     toDate(fecha_entrega, 'MM/dd/yyyy') ),",
				"          productos = initCap(lower(trim(productos))),",
				"          lote = upper(trim(lote)),",
				"          peso_kg = toDecimal(replace(trim(peso_kg), ',', '.'), 10, 2),",
				"          punto_entrega = initCap(lower(trim(punto_entrega)))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_agencia_id as integer,",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          fecha_entrega as date,",
				"          productos as string,",
				"          lote as string,",
				"          peso_kg as decimal(10,2),",
				"          punto_entrega as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     preSQLs:['DELETE FROM silver.spl_entregas_agencia;'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}