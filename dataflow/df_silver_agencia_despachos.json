{
	"name": "df_silver_agencia_despachos",
	"properties": {
		"folder": {
			"name": "silver/silver_agencia_sedem"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_agencia_despachos",
						"type": "DatasetReference"
					},
					"name": "srcbronzeagenciadespachos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_agencia_despachos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          despacho_id as string,",
				"          recepcion_id as string,",
				"          nro_lote as string,",
				"          almacen_id as string,",
				"          transportista_id as string,",
				"          vehiculo_id as string,",
				"          fecha_despacho as string,",
				"          cantidad_despachada as string,",
				"          centro_destino as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_despacho as string,",
				"          fecha_llegada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzeagenciadespachos",
				"srcbronzeagenciadespachos derive(despacho_id = toInteger(trim(despacho_id)),",
				"          recepcion_id = toInteger(trim(recepcion_id)),",
				"          nro_lote = upper(trim(nro_lote)),",
				"          almacen_id = toInteger(trim(almacen_id)),",
				"          transportista_id = toInteger(trim(transportista_id)),",
				"          vehiculo_id = toInteger(trim(vehiculo_id)),",
				"          fecha_despacho = coalesce(     toDate(fecha_despacho, 'yyyy-MM-dd'),     toDate(fecha_despacho, 'dd/MM/yyyy'),     toDate(fecha_despacho, 'dd-MM-yyyy'),     toDate(fecha_despacho, 'MM/dd/yyyy') ),",
				"          cantidad_despachada = toDecimal(replace(trim(cantidad_despachada), ',', '.'), 10, 2),",
				"          centro_destino = initCap(lower(trim(centro_destino))),",
				"          estado = initCap(lower(trim(estado))),",
				"          responsable = initCap(lower(trim(responsable))),",
				"          nro_guia_despacho = upper(trim(nro_guia_despacho)),",
				"          fecha_llegada = coalesce(     toDate(fecha_llegada, 'yyyy-MM-dd'),     toDate(fecha_llegada, 'dd/MM/yyyy'),     toDate(fecha_llegada, 'dd-MM-yyyy'),     toDate(fecha_llegada, 'MM/dd/yyyy') )) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          despacho_id as integer,",
				"          recepcion_id as integer,",
				"          nro_lote as string,",
				"          almacen_id as integer,",
				"          transportista_id as integer,",
				"          vehiculo_id as integer,",
				"          fecha_despacho as date,",
				"          cantidad_despachada as decimal(10,2),",
				"          centro_destino as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_despacho as string,",
				"          fecha_llegada as date",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}