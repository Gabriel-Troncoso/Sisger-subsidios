{
	"name": "df_gold_dim_programa",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_raw_programas_csv",
						"type": "DatasetReference"
					},
					"name": "srcprogramascsv"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_programa",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          codigo_programa as string,",
				"          nombre_programa as string,",
				"          tipo_beneficio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srcprogramascsv",
				"srcprogramascsv sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          programa_key as integer,",
				"          codigo_programa as string,",
				"          nombre_programa as string,",
				"          tipo_beneficio as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}