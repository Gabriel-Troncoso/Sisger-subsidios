{
	"name": "df_silver_sup_boletas",
	"properties": {
		"folder": {
			"name": "silver/silver_sup"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_sup_boletas",
						"type": "DatasetReference"
					},
					"name": "srcbronzesupboletas"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_sup_boletas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzesupboletas",
				"srcbronzesupboletas derive(boleta_id = toInteger(trim(boleta_id)),",
				"          control_id = toInteger(trim(control_id)),",
				"          ci_beneficiaria = upper(trim(ci_beneficiaria)),",
				"          nro_boleta = upper(trim(nro_boleta)),",
				"          fecha_emision = coalesce(     toDate(fecha_emision, 'yyyy-MM-dd'),     toDate(fecha_emision, 'dd/MM/yyyy'),     toDate(fecha_emision, 'dd-MM-yyyy'),     toDate(fecha_emision, 'MM/dd/yyyy') ),",
				"          estado = initCap(lower(trim(estado)))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          boleta_id as integer,",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as date,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}