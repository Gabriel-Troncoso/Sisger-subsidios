{
	"name": "df_silver_sup_inscripciones",
	"properties": {
		"folder": {
			"name": "silver/silver_sup"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_sup_inscripciones",
						"type": "DatasetReference"
					},
					"name": "srcbronzesupinscripciones"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_sup_inscripcionesSQL",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzesupinscripciones",
				"srcbronzesupinscripciones derive(inscripcion_id = toInteger(trim(inscripcion_id)),",
				"          ci_beneficiaria = upper(trim(ci_beneficiaria)),",
				"          establecimiento_id = toInteger(trim(establecimiento_id)),",
				"          fecha_inscripcion = coalesce(     toDate(fecha_inscripcion, 'yyyy-MM-dd'),     toDate(fecha_inscripcion, 'dd/MM/yyyy'),     toDate(fecha_inscripcion, 'dd-MM-yyyy'),     toDate(fecha_inscripcion, 'MM/dd/yyyy') ),",
				"          semana_gestacion = toInteger(trim(semana_gestacion)),",
				"          estado = initCap(lower(trim(estado)))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          inscripcion_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          fecha_inscripcion as date,",
				"          semana_gestacion as integer,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     preSQLs:['DELETE FROM silver.sup_inscripciones;'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}