{
	"name": "df_silver_spl_entregas_supermercado",
	"properties": {
		"folder": {
			"name": "silver/silver_spl"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_spl_entregas_supermercados",
						"type": "DatasetReference"
					},
					"name": "srcbronzesplentregassupermercado"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_spl_entregas_supermercado",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_super_id as string,",
				"          asignacion_id as string,",
				"          ci_beneficiaria as string,",
				"          supermercado_id as string,",
				"          fecha_retiro as string,",
				"          tipo_carne as string,",
				"          cantidad_kg as string,",
				"          monto_bs as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzesplentregassupermercado",
				"srcbronzesplentregassupermercado derive(entrega_super_id = toInteger(trim(entrega_super_id)),",
				"          asignacion_id = toInteger(trim(asignacion_id)),",
				"          ci_beneficiaria =  upper(trim(ci_beneficiaria)),",
				"          supermercado_id = toInteger(trim(supermercado_id)),",
				"          fecha_retiro = coalesce(     toDate(fecha_retiro, 'yyyy-MM-dd'),     toDate(fecha_retiro, 'dd/MM/yyyy'),     toDate(fecha_retiro, 'dd-MM-yyyy'),     toDate(fecha_retiro, 'MM/dd/yyyy') ),",
				"          tipo_carne = iif(regexMatch(lower(trim(tipo_carne)), `.*v.*c.*`), 'Vaca', iif(regexMatch(lower(trim(tipo_carne)), `.*p.*l.*`), 'Pollo', iif(regexMatch(lower(trim(tipo_carne)), `.*p.*sc.*`), 'Pescado', iif(regexMatch(lower(trim(tipo_carne)), `.*c.*r.*d.*`), 'Cerdo', initCap(lower(trim(tipo_carne))) )))),",
				"          cantidad_kg = toDecimal(replace(trim(cantidad_kg), ',', '.'), 10, 2),",
				"          monto_bs = toDecimal(replace(trim(monto_bs), ',', '.'), 10, 2)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_super_id as integer,",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          supermercado_id as integer,",
				"          fecha_retiro as date,",
				"          tipo_carne as string,",
				"          cantidad_kg as decimal(10,2),",
				"          monto_bs as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     preSQLs:['DELETE FROM silver.spl_entregas_supermercado;'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}