{
	"name": "df_gold_fact_beneficios_monetarios",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "AzureSqlTable2",
						"type": "DatasetReference"
					},
					"name": "srcbjapagos"
				},
				{
					"dataset": {
						"referenceName": "golddim_persona",
						"type": "DatasetReference"
					},
					"name": "srcgoldpersona"
				},
				{
					"dataset": {
						"referenceName": "golddim_programa",
						"type": "DatasetReference"
					},
					"name": "srcgoldprograma"
				},
				{
					"dataset": {
						"referenceName": "golddim_tiempo",
						"type": "DatasetReference"
					},
					"name": "srcgoldtiempo"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "joinbjapersona"
				},
				{
					"name": "joinbjaprograma"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "joinbjatiempo"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          pago_id as integer,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as decimal(10,2),",
				"          fecha_pago as date,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbjapagos",
				"source(output(",
				"          persona_key as integer,",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          nombre_completo as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          estado_civil as string,",
				"          numero_hijos as integer,",
				"          profesion as string,",
				"          municipio_residencia as string,",
				"          nivel_estudios as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcgoldpersona",
				"source(output(",
				"          programa_key as integer,",
				"          codigo_programa as string,",
				"          nombre_programa as string,",
				"          tipo_beneficio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcgoldprograma",
				"source(output(",
				"          fecha_key as integer,",
				"          fecha as date,",
				"          anio as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          trimestre as integer,",
				"          semestre as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcgoldtiempo",
				"derivedColumn2, derivedColumn3 join(ci_beneficiaria_join == ci_join,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinbjapersona",
				"derivedColumn1, srcgoldprograma join(codigo_programa_bja == codigo_programa,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinbjaprograma",
				"joinbjapersona derive(codigo_programa_bja = 'BJA') ~> derivedColumn1",
				"joinbjaprograma, srcgoldtiempo join(fecha_pago == fecha,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinbjatiempo",
				"joinbjatiempo select(mapColumn(",
				"          concepto = concepto_pago,",
				"          monto_bs,",
				"          estado_pago,",
				"          canal_pago,",
				"          persona_key,",
				"          programa_key,",
				"          fecha_key",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"srcbjapagos derive(ci_beneficiaria_join = upper(trim(ci_beneficiaria))) ~> derivedColumn2",
				"srcgoldpersona derive(ci_join = upper(trim(ci))) ~> derivedColumn3"
			]
		}
	}
}