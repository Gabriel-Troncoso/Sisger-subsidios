{
	"name": "df_silver_sup_catalogo_paquetes",
	"properties": {
		"folder": {
			"name": "silver/silver_sup"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_sup_catalogo_paquetes",
						"type": "DatasetReference"
					},
					"name": "srcbronzesupcatalogopaquetes"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_sup_catalogo_paquetesSQL",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          paquete_id as string,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as string,",
				"          costo_estimado_bs as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzesupcatalogopaquetes",
				"srcbronzesupcatalogopaquetes derive(paquete_id = toInteger(trim(paquete_id)),",
				"          nombre = initCap(lower(trim(nombre))),",
				"          contenido = trim(contenido),",
				"          peso_estandar_kg = toDecimal(replace(trim(peso_estandar_kg), ',', '.'), 10, 2),",
				"          costo_estimado_bs = toDecimal(replace(trim(costo_estimado_bs), ',', '.'), 10, 2)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paquete_id as integer,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(10,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     preSQLs:['DELETE FROM silver.sup_catalogo_paquetes;'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}