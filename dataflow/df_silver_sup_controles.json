{
	"name": "df_silver_sup_controles",
	"properties": {
		"folder": {
			"name": "silver/silver_sup"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_sup_controles",
						"type": "DatasetReference"
					},
					"name": "srcbronzesupcontroles"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_sup_controlesSQL",
						"type": "DatasetReference"
					},
					"name": "sinksilversupcontroles"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzesupcontroles",
				"srcbronzesupcontroles derive(control_id = toInteger(trim(control_id)),",
				"          ci_beneficiaria = upper(trim(ci_beneficiaria)),",
				"          establecimiento_id = toInteger(trim(establecimiento_id)),",
				"          nro_control = toInteger(trim(nro_control)),",
				"          fecha_control = coalesce(     toDate(fecha_control, 'yyyy-MM-dd'),     toDate(fecha_control, 'dd/MM/yyyy'),     toDate(fecha_control, 'dd-MM-yyyy'),     toDate(fecha_control, 'MM/dd/yyyy') ),",
				"          semana_gestacion = toInteger(trim(semana_gestacion)),",
				"          peso_madre_kg = toDecimal(replace(trim(peso_madre_kg), ',', '.'), 10, 2),",
				"          presion_arterial = upper(trim(presion_arterial))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(10,2),",
				"          presion_arterial as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     preSQLs:['DELETE FROM silver.sup_controles;'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinksilversupcontroles"
			]
		}
	}
}