{
	"name": "df_silver_bja_controles_pediatricos",
	"properties": {
		"folder": {
			"name": "silver/silver_bja"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_bja_controles_pediatricos",
						"type": "DatasetReference"
					},
					"name": "srcbronzebjacontrolespediatricos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_bja_controles_pediatricos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_pediatrico_id as string,",
				"          ci_nino as string,",
				"          ci_madre as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          peso_nino_kg as string,",
				"          talla_nino_cm as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzebjacontrolespediatricos",
				"srcbronzebjacontrolespediatricos derive(control_pediatrico_id = toInteger(trim(control_pediatrico_id)),",
				"          ci_nino = concat(   regexReplace(regexExtract(trim(ci_nino), `([\\d-]+)`, 1), `-`, ''),   iif(     regexMatch(upper(trim(ci_nino)), `.*(LP|SC|CB|OR|PT|TJ|CH|BN|PD).*`),     regexExtract(upper(trim(ci_nino)), `(LP|SC|CB|OR|PT|TJ|CH|BN|PD)`, 1),     'SINDPT'   ) ),",
				"          ci_madre = upper(trim(ci_madre)),",
				"          establecimiento_id = toInteger(trim(establecimiento_id)),",
				"          nro_control = toInteger(trim(nro_control)),",
				"          fecha_control = coalesce(     toDate(fecha_control, 'yyyy-MM-dd'),     toDate(fecha_control, 'dd/MM/yyyy'),     toDate(fecha_control, 'dd-MM-yyyy'),     toDate(fecha_control, 'MM/dd/yyyy') ),",
				"          peso_nino_kg = toDecimal(replace(trim(peso_nino_kg), ',', '.'), 10, 2),",
				"          talla_nino_cm = toDecimal(replace(trim(talla_nino_cm), ',', '.'), 10, 2)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_pediatrico_id as integer,",
				"          ci_nino as string,",
				"          ci_madre as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          peso_nino_kg as decimal(10,2),",
				"          talla_nino_cm as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     preSQLs:['DELETE FROM silver.bja_controles_pediatricos;'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}