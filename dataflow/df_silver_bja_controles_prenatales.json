{
	"name": "df_silver_bja_controles_prenatales",
	"properties": {
		"folder": {
			"name": "silver/silver_bja"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_bja_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "srcbronzebjacontrolesprenatales"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_bja_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_prenatal_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzebjacontrolesprenatales",
				"srcbronzebjacontrolesprenatales derive(control_prenatal_id = toInteger(trim(control_prenatal_id)),",
				"          ci_beneficiaria = upper(trim(ci_beneficiaria)),",
				"          establecimiento_id = toInteger(trim(establecimiento_id)),",
				"          nro_control = toInteger(trim(nro_control)),",
				"          fecha_control =  coalesce(     toDate(fecha_control, 'yyyy-MM-dd'),     toDate(fecha_control, 'dd/MM/yyyy'),     toDate(fecha_control, 'dd-MM-yyyy'),     toDate(fecha_control, 'MM/dd/yyyy') ),",
				"          semana_gestacion = toInteger(trim(semana_gestacion)),",
				"          peso_madre_kg = toDecimal(replace(trim(peso_madre_kg), ',', '.'), 10, 2),",
				"          presion_arterial = upper(trim(presion_arterial)),",
				"          resultado = iif(regexMatch(lower(trim(resultado)), `rie+sg?o+\\s+al+to+`), 'Riesgo Alto', iif(regexMatch(lower(trim(resultado)), `rie+sg?o+\\s+ba+jo+`), 'Riesgo Bajo', iif(regexMatch(lower(trim(resultado)), `rie+sg?o+\\s+no+r+m+a+l*`), 'Riesgo Normal', iif(regexMatch(lower(trim(resultado)), `no+r+m+a+l+`), 'Normal', iif(regexMatch(lower(trim(resultado)), `al+to+`), 'Alto', iif(regexMatch(lower(trim(resultado)), `ba+jo+`), 'Bajo', initCap(lower(trim(resultado))) ))))))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_prenatal_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(10,2),",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     preSQLs:['DELETE FROM silver.bja_controles_prenatales;'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}