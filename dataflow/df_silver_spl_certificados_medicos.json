{
	"name": "df_silver_spl_certificados_medicos",
	"properties": {
		"folder": {
			"name": "silver/silver_spl"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_spl_certificados_medicos",
						"type": "DatasetReference"
					},
					"name": "srcbronzesplcertificadosmedicos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_spl_certificados_medicos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          certificado_id as string,",
				"          afiliacion_id as string,",
				"          fecha_emision as string,",
				"          semana_gestacion as string,",
				"          fecha_probable_parto as string,",
				"          medico_responsable as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronzesplcertificadosmedicos",
				"srcbronzesplcertificadosmedicos derive(certificado_id = toInteger(trim(certificado_id)),",
				"          afiliacion_id = toInteger(trim(afiliacion_id)),",
				"          fecha_emision = coalesce(     toDate(fecha_emision, 'yyyy-MM-dd'),     toDate(fecha_emision, 'dd/MM/yyyy'),     toDate(fecha_emision, 'dd-MM-yyyy'),     toDate(fecha_emision, 'MM/dd/yyyy') ),",
				"          semana_gestacion = toInteger(trim(semana_gestacion)),",
				"          fecha_probable_parto = coalesce(     toDate(fecha_probable_parto, 'yyyy-MM-dd'),     toDate(fecha_probable_parto, 'dd/MM/yyyy'),     toDate(fecha_probable_parto, 'dd-MM-yyyy'),     toDate(fecha_probable_parto, 'MM/dd/yyyy') ),",
				"          medico_responsable = initCap(lower(trim(medico_responsable))),",
				"          estado = initCap(lower(trim(estado)))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          certificado_id as integer,",
				"          afiliacion_id as integer,",
				"          fecha_emision as date,",
				"          semana_gestacion as integer,",
				"          fecha_probable_parto as date,",
				"          medico_responsable as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     preSQLs:['DELETE FROM silver.spl_certificados_medicos;'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}